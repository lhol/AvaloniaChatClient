<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AvaloniaChatClient.ViewModels"
        xmlns:svc="using:AvaloniaChatClient.Services"
        xmlns:models="using:AvaloniaChatClient.Models"
        x:Class="AvaloniaChatClient.Views.ErrorLogWindow"
        x:DataType="vm:ErrorLogViewModel"
        Title="Fehlerprotokoll" Width="900" Height="600"
        WindowStartupLocation="CenterOwner">

  <Grid RowDefinitions="Auto,*,Auto" Margin="12">

    <!-- Toolbar -->
    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
      <Button Content="↻ Aktualisieren" Command="{Binding RefreshCommand}"/>
      <Button Content="Backend-Log leeren" Command="{Binding ClearBackendCommand}"
              Foreground="OrangeRed"/>
      <Button Content="Frontend-Log leeren" Command="{Binding ClearFrontendCommand}"
              Foreground="OrangeRed"/>
      <TextBlock VerticalAlignment="Center" Text="⏳" IsVisible="{Binding IsLoading}"/>
    </StackPanel>

    <!-- Two-pane: list left, details right -->
    <TabControl Grid.Row="1">

      <!-- Frontend errors -->
      <TabItem Header="Frontend">
        <Grid ColumnDefinitions="*,*">
          <ListBox Grid.Column="0" ItemsSource="{Binding FrontendErrors}"
                   SelectedItem="{Binding SelectedFrontendError}"
                   Margin="0,0,6,0">
            <ListBox.ItemTemplate>
              <DataTemplate DataType="svc:AppError">
                <StackPanel Spacing="2" Margin="2">
                  <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:HH:mm:ss}'}"
                             FontSize="11" Foreground="Gray"/>
                  <TextBlock Text="{Binding Context}" FontWeight="SemiBold" FontSize="13"/>
                  <TextBlock Text="{Binding UserMessage}" FontSize="12" TextWrapping="Wrap"/>
                </StackPanel>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
          <ScrollViewer Grid.Column="1">
            <TextBox Text="{Binding SelectedFrontendDetails}" IsReadOnly="True"
                     FontFamily="Cascadia Code,Consolas,monospace" FontSize="11"
                     TextWrapping="Wrap" AcceptsReturn="True" Background="Transparent"/>
          </ScrollViewer>
        </Grid>
      </TabItem>

      <!-- Backend errors -->
      <TabItem Header="Backend">
        <Grid ColumnDefinitions="*,*">
          <ListBox Grid.Column="0" ItemsSource="{Binding BackendErrors}"
                   SelectedItem="{Binding SelectedBackendError}"
                   Margin="0,0,6,0">
            <ListBox.ItemTemplate>
              <DataTemplate DataType="models:ErrorLogEntry">
                <StackPanel Spacing="2" Margin="2">
                  <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:HH:mm:ss}'}"
                             FontSize="11" Foreground="Gray"/>
                  <TextBlock Text="{Binding Context}" FontWeight="SemiBold" FontSize="13"/>
                  <TextBlock Text="{Binding UserMessage}" FontSize="12" TextWrapping="Wrap"/>
                </StackPanel>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
          <ScrollViewer Grid.Column="1">
            <TextBox Text="{Binding SelectedBackendDetails}" IsReadOnly="True"
                     FontFamily="Cascadia Code,Consolas,monospace" FontSize="11"
                     TextWrapping="Wrap" AcceptsReturn="True" Background="Transparent"/>
          </ScrollViewer>
        </Grid>
      </TabItem>

    </TabControl>

    <!-- Status bar -->
    <TextBlock Grid.Row="2" Margin="0,6,0,0" FontSize="11" Foreground="Gray"
               Text="{Binding BackendErrors.Count, StringFormat='Backend: {0} Einträge'}"/>

  </Grid>
</Window>
