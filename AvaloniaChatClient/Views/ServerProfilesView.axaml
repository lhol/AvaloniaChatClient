<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AvaloniaChatClient.ViewModels"
             xmlns:models="using:AvaloniaChatClient.Models"
             x:Class="AvaloniaChatClient.Views.ServerProfilesView"
             x:DataType="vm:ServerProfilesViewModel">

  <Grid RowDefinitions="Auto,*,Auto">

    <!-- Toolbar -->
    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="12,12,12,6">
      <TextBlock Text="Server-Profile" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
      <Button Content="＋ Neu" Command="{Binding StartCreateCommand}" Classes="accent"/>
    </StackPanel>

    <!-- Profile-Liste -->
    <ScrollViewer Grid.Row="1">
      <ItemsControl ItemsSource="{Binding Profiles}" Margin="12,0">
        <ItemsControl.ItemTemplate>
          <DataTemplate DataType="models:ServerProfile">
            <Border Margin="0,4" Padding="12" CornerRadius="6" Background="{DynamicResource SystemControlBackgroundAltHighBrush}">
              <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Spacing="2">
                  <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14"/>
                  <TextBlock FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}">
                    <Run Text="{Binding Url}"/>
                    <Run Text=":"/>
                    <Run Text="{Binding Port}"/>
                    <Run Text=" ["/>
                    <Run Text="{Binding Protocol}"/>
                    <Run Text="]"/>
                  </TextBlock>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                  <Button Content="Test"
                          Command="{Binding $parent[ItemsControl].((vm:ServerProfilesViewModel)DataContext).TestConnectionCommand}"
                          CommandParameter="{Binding}"/>
                  <Button Content="✎"
                          Command="{Binding $parent[ItemsControl].((vm:ServerProfilesViewModel)DataContext).StartEditCommand}"
                          CommandParameter="{Binding}"/>
                  <Button Content="🗑"
                          Command="{Binding $parent[ItemsControl].((vm:ServerProfilesViewModel)DataContext).DeleteCommand}"
                          CommandParameter="{Binding}"
                          Classes="danger"/>
                </StackPanel>
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>

    <!-- Statuszeile -->
    <TextBlock Grid.Row="2" Text="{Binding TestStatus}" Margin="12,4" FontSize="12"
               IsVisible="{Binding TestStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

    <!-- Edit-Overlay -->
    <Border Grid.Row="0" Grid.RowSpan="3"
            IsVisible="{Binding IsEditing}"
            Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
            Opacity="0.97" CornerRadius="8" Margin="8">
      <StackPanel Spacing="10" Margin="20" MaxWidth="420" VerticalAlignment="Center">
        <TextBlock Text="{Binding SelectedProfile, Converter={x:Static ObjectConverters.IsNull}, ConverterParameter='Neues Profil|Profil bearbeiten'}"
                   FontSize="16" FontWeight="SemiBold"/>

        <TextBox PlaceholderText="Name" Text="{Binding EditName}"/>
        <TextBox PlaceholderText="URL (z.B. http://localhost)" Text="{Binding EditUrl}"/>
        <NumericUpDown Value="{Binding EditPort}" Minimum="1" Maximum="65535" FormatString="0" Increment="1"/>
        <TextBox PlaceholderText="Token (optional)" Text="{Binding EditToken}" PasswordChar="●"/>
        <ComboBox ItemsSource="{Binding Protocols}" SelectedItem="{Binding EditProtocol}" HorizontalAlignment="Stretch"/>

        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
          <Button Content="Abbrechen" Command="{Binding CancelEditCommand}"/>
          <Button Content="Speichern" Command="{Binding SaveCommand}" Classes="accent"/>
        </StackPanel>
      </StackPanel>
    </Border>

  </Grid>
</UserControl>
