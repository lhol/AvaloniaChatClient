<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Avaiu.ViewModels"
             xmlns:views="using:Avaiu.Views"
             x:Class="Avaiu.Views.MainView"
             x:DataType="vm:MainViewModel">

  <Grid RowDefinitions="Auto,*">

    <!-- Topbar -->
    <Border Grid.Row="0" Padding="12,8" BorderThickness="0,0,0,1"
            BorderBrush="{DynamicResource SystemControlBackgroundBaseLowBrush}">
      <Grid ColumnDefinitions="Auto,*,Auto,Auto">
        <TextBlock Grid.Column="0" Text="Avaiu" FontSize="16" FontWeight="Bold"
                   VerticalAlignment="Center"/>
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
          <Ellipse Width="8" Height="8" Fill="Red" IsVisible="{Binding !BackendReachable}"/>
          <Ellipse Width="8" Height="8" Fill="LimeGreen" IsVisible="{Binding BackendReachable}"/>
          <TextBlock Text="{Binding BackendStatus}" FontSize="12"
                     Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
        </StackPanel>
        <Button Grid.Column="2" Content="＋ Neue Session"
                Command="{Binding OpenNewSessionDialogCommand}"
                Classes="accent" Margin="0,0,8,0"/>
        <Button Grid.Column="3"
                Command="{Binding OpenErrorLogCommand}"
                ToolTip.Tip="Fehlerprotokoll öffnen">
          <StackPanel Orientation="Horizontal" Spacing="4">
            <TextBlock Text="⚠" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding ErrorCount}" VerticalAlignment="Center"/>
          </StackPanel>
        </Button>
      </Grid>
    </Border>

    <!-- Main body: left sidebar + right content -->
    <Grid Grid.Row="1" x:Name="MainBodyGrid">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="{Binding IsSidebarCollapsed, Converter={StaticResource BoolToGridLengthConverter}}"/>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <!-- LEFT SIDEBAR -->
      <Grid Grid.Column="0" RowDefinitions="Auto,*,Auto">

        <!-- Sidebar header with fold button -->
        <Border Grid.Row="0" BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                Padding="4,4">
          <Grid ColumnDefinitions="Auto,*">
            <Button Grid.Column="0"
                    Command="{Binding ToggleSidebarCommand}"
                    Padding="6,4" Background="Transparent" BorderThickness="0"
                    ToolTip.Tip="{Binding IsSidebarCollapsed, Converter={StaticResource BoolToChevronConverter}}">
              <TextBlock Text="{Binding IsSidebarCollapsed, Converter={StaticResource BoolToChevronConverter}}"
                         FontSize="12"/>
            </Button>
            <TextBlock Grid.Column="1" Text="Aktive Sessions" FontWeight="SemiBold" FontSize="13"
                       VerticalAlignment="Center" Margin="4,0,0,0"
                       IsVisible="{Binding !IsSidebarCollapsed}"/>
          </Grid>
        </Border>

        <!-- Session group tree (expanded mode only) -->
        <ScrollViewer Grid.Row="1" IsVisible="{Binding !IsSidebarCollapsed}">
          <ItemsControl ItemsSource="{Binding SessionGroups}">
            <ItemsControl.ItemTemplate>
              <DataTemplate DataType="vm:SessionGroupViewModel">
                <StackPanel>
                  <!-- Group header row (collapsible) -->
                  <Button Background="Transparent" HorizontalAlignment="Stretch"
                          HorizontalContentAlignment="Left"
                          Padding="8,5" BorderThickness="0"
                          Command="{Binding ToggleExpandedCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="5">
                      <TextBlock Text="{Binding IsExpanded, Converter={StaticResource BoolToChevronConverter}}"
                                 FontSize="10" VerticalAlignment="Center"/>
                      <TextBlock Text="{Binding Topic}" FontWeight="SemiBold" FontSize="12"
                                 VerticalAlignment="Center"/>
                    </StackPanel>
                  </Button>
                  <!-- Sub-groups (2-level topics "Parent/Child") -->
                  <ItemsControl ItemsSource="{Binding SubGroups}"
                                IsVisible="{Binding IsExpanded}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate DataType="vm:SessionGroupViewModel">
                        <StackPanel>
                          <!-- Sub-group header -->
                          <Button Background="Transparent" HorizontalAlignment="Stretch"
                                  HorizontalContentAlignment="Left"
                                  Padding="18,4" BorderThickness="0"
                                  Command="{Binding ToggleExpandedCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="5">
                              <TextBlock Text="{Binding IsExpanded, Converter={StaticResource BoolToChevronConverter}}"
                                         FontSize="9" VerticalAlignment="Center"/>
                              <TextBlock Text="{Binding Topic}" FontSize="11" FontStyle="Italic"
                                         VerticalAlignment="Center"/>
                            </StackPanel>
                          </Button>
                          <!-- Sessions within sub-group -->
                          <ItemsControl ItemsSource="{Binding Sessions}"
                                        IsVisible="{Binding IsExpanded}">
                            <ItemsControl.ItemTemplate>
                              <DataTemplate DataType="vm:ChatSessionViewModel">
                                <Button HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Left"
                                        Padding="28,5,6,5" Margin="0,1,0,0"
                                        ToolTip.Tip="{Binding TabTooltip}"
                                        Command="{Binding $parent[UserControl].((vm:MainViewModel)DataContext).ActivateSessionCommand}"
                                        CommandParameter="{Binding}"
                                        Classes="session-btn"
                                        Classes.active="{Binding IsActive}">
                                  <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Grid.Column="0" Spacing="1">
                                      <TextBlock Text="{Binding Title}" TextTrimming="CharacterEllipsis"
                                                 FontSize="13"/>
                                      <TextBlock Text="{Binding Comment}" FontSize="10"
                                                 TextTrimming="CharacterEllipsis"
                                                 IsVisible="{Binding Comment, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                 Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="✕" Padding="3,1"
                                            Background="Transparent" BorderThickness="0" FontSize="11"
                                            Command="{Binding $parent[UserControl].((vm:MainViewModel)DataContext).CloseSessionCommand}"
                                            CommandParameter="{Binding}"/>
                                  </Grid>
                                  <Button.ContextMenu>
                                    <ContextMenu>
                                      <MenuItem Header="Titel / Kommentar / Thema bearbeiten"
                                                Command="{Binding StartEditMetaCommand}"/>
                                    </ContextMenu>
                                  </Button.ContextMenu>
                                </Button>
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                        </StackPanel>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                  <!-- Sessions directly within top-level group (no sub-groups) -->
                  <ItemsControl ItemsSource="{Binding Sessions}"
                                IsVisible="{Binding IsExpanded}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate DataType="vm:ChatSessionViewModel">
                        <Button HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                Padding="18,5,6,5" Margin="0,1,0,0"
                                ToolTip.Tip="{Binding TabTooltip}"
                                Command="{Binding $parent[UserControl].((vm:MainViewModel)DataContext).ActivateSessionCommand}"
                                CommandParameter="{Binding}"
                                Classes="session-btn"
                                Classes.active="{Binding IsActive}">
                          <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" Spacing="1">
                              <TextBlock Text="{Binding Title}" TextTrimming="CharacterEllipsis"
                                         FontSize="13"/>
                              <TextBlock Text="{Binding Comment}" FontSize="10"
                                         TextTrimming="CharacterEllipsis"
                                         IsVisible="{Binding Comment, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                         Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                            </StackPanel>
                            <!-- Close button -->
                            <Button Grid.Column="1" Content="✕" Padding="3,1"
                                    Background="Transparent" BorderThickness="0" FontSize="11"
                                    Command="{Binding $parent[UserControl].((vm:MainViewModel)DataContext).CloseSessionCommand}"
                                    CommandParameter="{Binding}"/>
                          </Grid>
                          <Button.ContextMenu>
                            <ContextMenu>
                              <MenuItem Header="Titel / Kommentar / Thema bearbeiten"
                                        Command="{Binding StartEditMetaCommand}"/>
                            </ContextMenu>
                          </Button.ContextMenu>
                        </Button>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>

        <!-- Nav buttons at bottom of sidebar -->
        <StackPanel Grid.Row="2" Spacing="2" Margin="4,4">
          <!-- Expanded mode: full buttons with text -->
          <StackPanel IsVisible="{Binding !IsSidebarCollapsed}" Spacing="2">
            <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                    Padding="10,6" Background="Transparent" BorderThickness="0"
                    Command="{Binding SwitchToServerTabCommand}">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="⚙" FontSize="14" VerticalAlignment="Center"/>
                <TextBlock Text="Server" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>
            <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                    Padding="10,6" Background="Transparent" BorderThickness="0"
                    Command="{Binding SwitchToHistoryTabCommand}">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="🕐" FontSize="14" VerticalAlignment="Center"/>
                <TextBlock Text="Historien" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>
            <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                    Padding="10,6" Background="Transparent" BorderThickness="0"
                    Command="{Binding SwitchToSkillsTabCommand}">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="🎓" FontSize="14" VerticalAlignment="Center"/>
                <TextBlock Text="Skills" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>
          </StackPanel>
          <!-- Collapsed mode: icon-only buttons -->
          <StackPanel IsVisible="{Binding IsSidebarCollapsed}" Spacing="2">
            <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                    Padding="6,8" Background="Transparent" BorderThickness="0"
                    ToolTip.Tip="Chat"
                    Command="{Binding ExpandSidebarForChatCommand}">
              <TextBlock Text="💬" FontSize="16"/>
            </Button>
            <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                    Padding="6,8" Background="Transparent" BorderThickness="0"
                    ToolTip.Tip="Server"
                    Command="{Binding SwitchToServerTabCommand}">
              <TextBlock Text="⚙" FontSize="16"/>
            </Button>
            <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                    Padding="6,8" Background="Transparent" BorderThickness="0"
                    ToolTip.Tip="Historien"
                    Command="{Binding SwitchToHistoryTabCommand}">
              <TextBlock Text="🕐" FontSize="16"/>
            </Button>
            <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                    Padding="6,8" Background="Transparent" BorderThickness="0"
                    ToolTip.Tip="Skills"
                    Command="{Binding SwitchToSkillsTabCommand}">
              <TextBlock Text="🎓" FontSize="16"/>
            </Button>
          </StackPanel>
        </StackPanel>
      </Grid>

      <!-- Vertical splitter -->
      <GridSplitter Grid.Column="1" Width="3"
                    ResizeDirection="Columns"
                    Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"/>

      <!-- RIGHT CONTENT AREA: tabs for Chat / Server / History -->
      <Grid Grid.Column="2">
        <TabControl SelectedIndex="{Binding SelectedTabIndex}">

          <!-- Tab 0: Server-Profile -->
          <TabItem Header="Server">
            <views:ServerProfilesView DataContext="{Binding ServerProfiles}"/>
          </TabItem>

          <!-- Tab 1: Chat -->
          <TabItem Header="Chat">
            <Grid x:DataType="vm:MainViewModel">
              <TextBlock Text="Keine aktive Session. Klicke '＋ Neue Session'."
                         HorizontalAlignment="Center" VerticalAlignment="Center"
                         Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                         IsVisible="{Binding ActiveSession, Converter={x:Static ObjectConverters.IsNull}}"/>
              <ContentControl Content="{Binding ActiveSession}"
                              IsVisible="{Binding ActiveSession, Converter={x:Static ObjectConverters.IsNotNull}}">
                <ContentControl.ContentTemplate>
                  <DataTemplate DataType="vm:ChatSessionViewModel">
                    <views:ChatSessionView/>
                  </DataTemplate>
                </ContentControl.ContentTemplate>
              </ContentControl>
            </Grid>
          </TabItem>

          <!-- Tab 2: History -->
          <TabItem Header="Historien">
            <views:HistoryView DataContext="{Binding History}"/>
          </TabItem>

          <!-- Tab 3: Skills -->
          <TabItem Header="Skills">
            <views:SkillsView DataContext="{Binding History}"/>
          </TabItem>

        </TabControl>
      </Grid>
    </Grid>

    <!-- Dialog: Neue Session -->
    <Panel IsVisible="{Binding IsNewSessionDialogOpen}" Grid.Row="0" Grid.RowSpan="2"
           Background="#80000000">
      <Border Padding="24" CornerRadius="10" MaxWidth="440"
              Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
              HorizontalAlignment="Center" VerticalAlignment="Center">
        <StackPanel Spacing="12">
          <TextBlock Text="Neue Chat-Session" FontSize="16" FontWeight="SemiBold"/>

          <TextBlock Text="Server:" FontSize="13"/>
          <ComboBox ItemsSource="{Binding AvailableServers}"
                    SelectedItem="{Binding NewSessionServer}"
                    HorizontalAlignment="Stretch">
            <ComboBox.ItemTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding Name}"/>
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>

          <TextBlock Text="Modell:" FontSize="13"/>
          <TextBox Text="{Binding NewSessionModel}" PlaceholderText="z.B. llama3, gpt-4o"/>

          <TextBlock Text="Titel (optional):" FontSize="13"/>
          <TextBox Text="{Binding NewSessionTitle}" PlaceholderText="Neue Session"/>

          <TextBlock Text="Kommentar (optional):" FontSize="13"/>
          <TextBox Text="{Binding NewSessionComment}" PlaceholderText="Kurzbeschreibung"/>

          <TextBlock Text="Thema (optional):" FontSize="13"/>
          <AutoCompleteBox Text="{Binding NewSessionTopic}"
                           ItemsSource="{Binding ExistingTopics}"
                           FilterMode="Contains"
                           PlaceholderText="z.B. Arbeit oder Arbeit/Notizen"/>

          <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
            <Button Content="Abbrechen" Command="{Binding CancelNewSessionCommand}"/>
            <Button Content="Erstellen" Command="{Binding CreateSessionCommand}" Classes="accent"/>
          </StackPanel>
        </StackPanel>
      </Border>
    </Panel>

  </Grid>
</UserControl>
